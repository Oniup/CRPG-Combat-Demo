build src/game/environment/CMakeFiles/install/strip.util: CUSTOM_COMMAND src/game/environment/all
  COMMAND = C:\WINDOWS\system32\cmd.exe /C "cd /D "C:\Dev\Custom Project\build\src\game\environment" && "C:\Program Files\CMake\bin\cmake.exe" -DCMAKE_INSTALL_DO_STRIP=1 -P cmake_install.cmake"
  DESC = Installing the project stripped...
  pool = console
  restat = 1

build src/game/environment/install/strip: phony src/game/environment/CMakeFiles/install/strip.util

